# Banco (usado pelo serviço "db" do docker-compose)
POSTGRES_USER=helpdesk
POSTGRES_PASSWORD=helpdesk
POSTGRES_DB=smarthelpdesk

# Usado pela API (host "db" = nome do serviço no docker-compose)
DATABASE_URL=postgresql://helpdesk:helpdesk@db:5432/smarthelpdesk

# API
PORT=3000

# Auth
JWT_SECRET=troque-este-valor
JWT_EXPIRES_IN=1d

# IA — Google Gemini (obter a chave em https://aistudio.google.com)
GEMINI_API_KEY=coloque-sua-chave-aqui
GEMINI_MODEL=gemini-2.5-flash

# E-mail (notificações)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Cloudflare Tunnel (opcional, só para expor o ambiente local — ver README).
# Deixe em branco para usar o modo rápido (URL aleatória *.trycloudflare.com).
# Preencha com o token de um túnel nomeado (painel Cloudflare Zero Trust) para
# usar domínio próprio.
CLOUDFLARE_TUNNEL_TOKEN=
# Alvo do túnel no modo rápido (padrão: o front-end). Troque para
# http://api:3000 se quiser expor a API em vez do front.
CLOUDFLARE_TUNNEL_URL=http://web:5173
